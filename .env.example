# TarotByte — Environment Variables Template
# ------------------------------------------------------------------
# Copy this file to `.env.local` for local dev, and add the SAME keys
# in the Vercel dashboard (Project → Settings → Environment Variables)
# for production. NEVER put real values in this file — it's committed
# to a PUBLIC repo. Real values live only in .env.local (gitignored)
# and in Vercel.
# ------------------------------------------------------------------

# --- App ---
# Your production URL (used for absolute links, Stripe redirects, emails)
NEXT_PUBLIC_SITE_URL="https://tarotbyte.app"

# --- Supabase (Phase C: accounts, tiers, saved readings) ---
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""            # e.g. https://xxxx.supabase.co  (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""       # public anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=""           # SECRET — server only, never expose to browser

# --- Stripe (Phase D: add-on + subscription) ---
# From Stripe → Developers → API keys. Use TEST keys first (pk_test_ / sk_test_).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # pk_test_... then pk_live_...
STRIPE_SECRET_KEY=""                   # SECRET — sk_test_... then sk_live_...
STRIPE_WEBHOOK_SECRET=""               # SECRET — from the Stripe webhook you create (whsec_...)
# Price IDs live in lib/stripeConfig.js (non-secret, safe to ship in the bundle).
# Prices already created on the live account:
#   decan_member_single = $2.00 one-time
#   decan_list_single   = $4.00 one-time
#   decan_3pack         = $5.00 one-time (3 credits)
#   sub_monthly         = $6.99/month
#   sub_annual          = $49.00/year

# --- Email (Phase E: auth emails + The Weekly Byte) ---
# Resend (transactional). From resend.com → API Keys.
RESEND_API_KEY=""                      # SECRET
EMAIL_FROM="hello@tarotbyte.app"       # must be a verified domain sender

# --- AI narration (Phase F: live reading interpretation) ---
# Use ONE of these. Set a monthly spend cap in the provider dashboard.
OPENAI_API_KEY=""                      # SECRET — sk-...
# ANTHROPIC_API_KEY=""                 # SECRET — alternative to OpenAI
